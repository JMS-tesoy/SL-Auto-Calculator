{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Position Calculator for OKX",
  "version": "1.0.0",
  "identifier": "com.okx.position-calculator",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npx http-server dist -p 1420 --cors -c-1"
  },
  "app": {
    "windows": [
      {
        "title": "Position Calculator for OKX",
        "width": 1200,
        "height": 720,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}